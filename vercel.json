{
  "version": 2,
  "name": "ancuu-galleria-hue",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/bat-dong-san",
      "dest": "/pages/bat-dong-san.html"
    },
    {
      "src": "/bat-dong-san/(.*)",
      "dest": "/pages/chi-tiet-bds.html"
    },
    {
      "src": "/du-an",
      "dest": "/pages/du-an.html"
    },
    {
      "src": "/du-an/an-cuu-galleria",
      "dest": "/pages/du-an/an-cuu-galleria.html"
    },
    {
      "src": "/gia-dat-hue",
      "dest": "/pages/gia-dat-hue.html"
    },
    {
      "src": "/gia-dat-hue/an-cuu",
      "dest": "/pages/gia-dat-hue/an-cuu.html"
    },
    {
      "src": "/blog",
      "dest": "/pages/blog.html"
    },
    {
      "src": "/gioi-thieu",
      "dest": "/pages/gioi-thieu.html"
    },
    {
      "src": "/lien-he",
      "dest": "/pages/lien-he.html"
    },
    {
      "src": "/chinh-sach-bao-mat",
      "dest": "/pages/chinh-sach-bao-mat.html"
    },
    {
      "src": "/dieu-khoan",
      "dest": "/pages/dieu-khoan.html"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
